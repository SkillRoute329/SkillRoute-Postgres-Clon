rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // HELPERS — RBAC
    // ============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Acepta tanto "role" como "rol" y normaliza a minúsculas
    function getUserRole() {
      let d = userDoc();
      return d.keys().hasAny(['role'])
        ? d.role.lower()
        : (d.keys().hasAny(['rol']) ? d.rol.lower() : 'none');
    }

    // Nota: isAdmin() eliminada 2026-04-23 — no se usaba en ninguna regla
    // (todas las colecciones usan isAdminNorm()). La versión antigua hacía
    // comparaciones case-sensitive innecesarias dado que getUserRole() ya
    // normaliza a minúsculas.

    function isAdminNorm() {
      let r = getUserRole();
      return r == 'admin' || r == 'superadmin';
    }

    function isTrafficOrAdmin() {
      let r = getUserRole();
      return r in ['admin', 'superadmin', 'traffic', 'traffic_manager', 'listero', 'inspector'];
    }

    function isDriver() {
      let r = getUserRole();
      return r in ['driver', 'conductor', 'chofer'];
    }

    function isInspector() {
      return getUserRole() in ['inspector', 'admin', 'superadmin'];
    }

    function isHR() {
      return getUserRole() in ['rrhh', 'hr', 'admin', 'superadmin'];
    }

    // ============================================================
    // USUARIOS
    // ============================================================
    match /users/{userId} {
      // Cualquier autenticado puede leer (necesario para listero/turnos con login anónimo)
      allow read: if isAuthenticated();
      // Solo el propio usuario o admin puede escribir
      allow write: if request.auth.uid == userId || isAdminNorm();
    }

    // ============================================================
    // FLOTA
    // ============================================================
    match /vehiculos/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    match /fleet/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    // ============================================================
    // CARTONES Y SERVICIOS
    // ============================================================
    match /cartones/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    match /service_definitions/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    match /cartones_de_servicio/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isTrafficOrAdmin();
    }

    // ============================================================
    // OPERACIONES DIARIAS
    // ============================================================
    match /programacion_diaria/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isTrafficOrAdmin();
    }

    match /programacion_semanal/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isTrafficOrAdmin();
    }

    match /servicio_estado/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isTrafficOrAdmin();
    }

    match /active_assignments/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isTrafficOrAdmin();
    }

    match /coche_personal/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isTrafficOrAdmin();
    }

    match /correlativos/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isTrafficOrAdmin();
    }

    // ============================================================
    // PERSONAL Y RRHH
    // ============================================================
    match /personal/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isHR();
    }

    match /shifts/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isHR() || isTrafficOrAdmin();
    }

    match /exceptions/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isHR();
    }

    match /rotation_rules/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    match /personal_rotation/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isHR();
    }

    // ============================================================
    // INSPECCIONES Y MANTENIMIENTO
    // ============================================================
    match /inspecciones_flota/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isInspector() || isAdminNorm();
    }

    // Registros de inspección de campo (InspectorCapture → InspectorDashboard → OTPDashboard)
    match /inspections/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isInspector() || isTrafficOrAdmin();
    }

    match /maintenance/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    match /mantenimiento_logs/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    match /notificaciones_flota/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isTrafficOrAdmin();
    }

    match /logs_incidencias/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ============================================================
    // CONFLICTOS Y ALERTAS
    // ============================================================
    match /assignment_conflicts/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isTrafficOrAdmin();
    }

    match /alertas_regulacion/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isInspector() || isAdminNorm();
    }

    // alertas_log: log append-only generado por shadowDispatcher para analytics
    // historico cross-operador. Solo lectura autenticada; escritura solo desde
    // Cloud Functions (admin SDK bypass).
    match /alertas_log/{document=**} {
      allow read: if isAuthenticated();
      allow write: if false; // solo Cloud Functions admin SDK
    }

    match /alertas_trafico/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isTrafficOrAdmin();
    }

    match /road_alerts/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isTrafficOrAdmin();
    }

    // ============================================================
    // INTELIGENCIA DE RED — CORREDORES (DRO MATRIX)
    // (matriz pre-calculada por Cloud Function droMatrix.ts;
    // lectura abierta a cualquier usuario autenticado para que
    // CEODashboardV7, CorridorIntelligence, ShadowRadar y CorridorMap
    // puedan consumirla; escritura sólo desde Cloud Functions
    // admin SDK que bypass de las rules.)
    // ============================================================
    match /corridor_overlap/{document=**} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /shapes_cross_operator/{document=**} {
      // Lectura pública — datos de rutas oficiales IMM, no contienen info sensible.
      // Escritura: solo admin SDK (gtfsImporter + shapeBuilder Cloud Function).
      allow get, list: if true;
      allow write: if false;
    }

    match /gtfs_horarios/{document=**} {
      // Horarios oficiales GTFS (importados semanalmente por gtfsImporter).
      // Lectura pública — datos de horarios oficiales IMM, no contienen info sensible.
      // Escritura: solo Cloud Function (Admin SDK, sin auth).
      allow get, list: if true;
      allow write: if false;
    }

    match /gtfs_calendar/{document=**} {
      // Calendario GTFS por línea — patrones hábil/sábado/domingo y vigencias.
      // Lectura pública — datos de servicio oficiales IMM, sin información sensible.
      // Escritura: solo Cloud Function (Admin SDK, sin auth).
      allow get, list: if true;
      allow write: if false;
    }

    match /gtfs_stops/{document=**} {
      // Paradas GTFS — nombre, lat/lng y accesibilidad de las ~4938 paradas del STM.
      // Lectura pública — datos de infraestructura oficiales IMM, sin información sensible.
      // Escritura: solo Cloud Function (Admin SDK, sin auth).
      allow get, list: if true;
      allow write: if false;
    }

    match /gtfs_fares/{document=**} {
      // Tarifas GTFS — precio por línea/empresa en moneda local.
      // Lectura pública — datos tarifarios oficiales IMM, sin información sensible.
      // Escritura: solo Cloud Function (Admin SDK, sin auth).
      allow get, list: if true;
      allow write: if false;
    }

    match /gtfs_timetable/{document=**} {
      // Horarios completos GTFS por línea/dirección/tipo de servicio.
      // Compact format: stops[] + viajes[{s,t[]}] para consultas de próximo bus.
      // Lectura pública — datos de servicio oficiales IMM, sin información sensible.
      // Escritura: solo Cloud Function (Admin SDK, sin auth).
      allow get, list: if true;
      allow write: if false;
    }

    match /bus_delays/{document=**} {
      // Retraso actual por bus — calculado por otpEngine cada 10 min.
      // Lectura pública para demo — contiene posición/delay de buses activos (no PII).
      // Escritura: solo Cloud Function (Admin SDK, sin auth).
      allow get, list: if true;
      allow write: if false;
    }

    match /otp_summary/{document=**} {
      // Resumen de puntualidad por línea — % a tiempo, retraso promedio, buses activos.
      // Lectura pública para demo.
      // Escritura: solo Cloud Function (Admin SDK, sin auth).
      allow get, list: if true;
      allow write: if false;
    }

    // ============================================================
    // INCIDENCIAS OPERACIONALES (centro de incidencias)
    // ============================================================
    match /incidencias/{document=**} {
      allow read: if isAuthenticated();
      // Conductor puede CREAR si reportedBy.uid coincide con su uid.
      // Admin/tráfico/inspector también pueden crear (ej. despacho reporta por conductor).
      allow create: if isAuthenticated()
        && (request.resource.data.reportedBy.uid == request.auth.uid
            || isAdminNorm() || isTrafficOrAdmin() || isInspector());
      allow update, delete: if isAdminNorm() || isTrafficOrAdmin() || isInspector();
    }

    // ============================================================
    // MENSAJES Y COMUNICACIONES
    // ============================================================
    match /mensajes_internos/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /bulletins/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    // ============================================================
    // PARÁMETROS DEL SISTEMA (con trazabilidad histórica)
    // Lectura: cualquier autenticado (para simuladores y cálculos).
    // Escritura: solo admin — nunca se editan versiones pasadas,
    //            solo se agregan nuevas vía arrayUnion.
    // ============================================================
    match /parametros_sistema/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    // ============================================================
    // CONFIGURACIÓN DEL SISTEMA
    // ============================================================
    match /system/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    match /system_config/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    match /vehicle_categories/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    match /service_category_assignments/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    match /departments/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    // ============================================================
    // INTELIGENCIA / STM (HARDENED)
    // ============================================================
    match /stm_horarios/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isTrafficOrAdmin();
    }

    match /stm_sincronizaciones/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isTrafficOrAdmin();
    }

    match /stm_alertas_competencia/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isTrafficOrAdmin();
    }

    // Alertas automáticas de cumplimiento (pobladas por complianceAlertsTick cada 6h).
    // Lectura: tráfico + admin. Escritura: solo backend (admin SDK).
    // El campo dismissed lo puede actualizar tráfico (descartar desde la UI).
    match /compliance_alerts/{document=**} {
      allow read: if isAuthenticated();
      allow update: if isTrafficOrAdmin() && request.resource.data.keys().hasOnly(['dismissed', 'dismissedBy', 'dismissedAt']);
      allow write: if isAdminNorm();
    }

    match /competencia_monitoreo/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isTrafficOrAdmin();
    }

    // Identidad + operación agregada por empresa competidora (COETC/COME/CUTCSA).
    // Poblada por el cron refreshCompetidoresTick (cada 10min) y por el trigger
    // manual POST /api/competition/sync-from-stm.
    match /competidores/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isTrafficOrAdmin();
    }

    // Audit trail de cada snapshot GPS del endpoint IMM stm-online.
    // Solo lectura para admin; escritura desde el cron server-side.
    match /stm_snapshots/{document=**} {
      allow read: if isAdminNorm() || isTrafficOrAdmin();
      allow write: if isAdminNorm() || isTrafficOrAdmin();
    }

    match /scrapping_logs/{document=**} {
      allow read: if isAdminNorm();
      allow write: if isAdminNorm();
    }

    match /shadow_tracker/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isDriver() || isTrafficOrAdmin();
    }

    match /viajes_activos/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isDriver() || isTrafficOrAdmin();
    }

    match /lineas/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    match /recomendaciones/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isTrafficOrAdmin();
    }

    match /boletaje/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    match /penalties/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm() || isTrafficOrAdmin();
    }

    match /discounts/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    match /data_import/{document=**} {
      allow read: if isAdminNorm();
      allow write: if isAdminNorm();
    }

    match /system_health/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    match /service_matrix/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    // ============================================================
    // IA — SUGERENCIAS DEL COPILOTO (ai_orders)
    //   - Creación: SOLO backend (service account bypass). Nunca cliente.
    //   - Lectura: cualquier usuario autenticado (para inbox de inspector).
    //   - Update: prohibido al cliente. Aprobación/rechazo pasan por REST
    //     que valida rol y transición de estado.
    // ============================================================
    match /ai_orders/{document=**} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // ============================================================
    // PARÁMETROS OPERATIVOS (tarifa, costos, elasticidad, radios…)
    //   - Lectura: cualquier autenticado (los módulos los consultan).
    //   - Escritura: solo admin/superadmin (UI Super Admin).
    //   - Fase 1 (2026-04-23): fuente única de verdad editable.
    // ============================================================
    match /parametros_operativos/{key} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    // Historial de cambios — audit trail inmutable:
    //   - Lectura: solo admin (review de cambios).
    //   - Creación: solo admin (se escribe desde el mismo flow que el update).
    //   - Update/delete: prohibido a cliente — preserva el historial.
    match /parametros_operativos_historial/{document=**} {
      allow read: if isAdminNorm();
      allow create: if isAdminNorm();
      allow update, delete: if false;
    }

    // ============================================================
    // AUDIT LOG general (Cloud Function trigger onWrite — 2026-04-25)
    //   - Read: sólo admin (revisión de cambios).
    //   - Write: prohibido al cliente. Sólo Cloud Functions vía service
    //     account pueden escribir (los triggers usan creds de admin).
    //   - Update/delete: prohibido (audit trail inmutable).
    // ============================================================
    match /audit_log/{document=**} {
      allow read: if isAdminNorm();
      allow write: if false;
    }

    // ============================================================
    // DISRUPCIONES OPERACIONALES (Disruption Management — Trim+ #67)
    //   - Lectura: cualquier autenticado (visibilidad para flota).
    //   - Create: cualquier autenticado (reporte desde cualquier rol).
    //   - Update: traffic / admin (transición de estado).
    //   - Delete: prohibido (audit trail).
    // ============================================================
    match /disruptions/{document=**} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdminNorm() || isTrafficOrAdmin();
      allow delete: if false;
    }

    // ============================================================
    // DESVÍOS REPORTADOS POR CONDUCTOR (BusNavigation — Pre-CUTCSA #6)
    //   - Creación: cualquier autenticado (conductor reporta en calle).
    //   - Lectura: cualquier autenticado (flota + control tráfico).
    //   - Update: solo admin/traffic (cierran o reclasifican).
    //   - Delete: prohibido (audit trail).
    // ============================================================
    match /desvios_reportados/{document=**} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdminNorm() || isTrafficOrAdmin();
      allow delete: if false;
    }

    // ============================================================
    // DESVÍOS GUARDADOS — overlays de ruta alternativa por línea
    //   (Navegador: TrafficModule → panel Desvíos → mapa editor).
    //   - Lectura: cualquier autenticado.
    //   - Escritura: solo TRAFFIC o ADMIN.
    //   - Delete: prohibido (audit trail).
    // ============================================================
    match /desvios_guardados/{document=**} {
      allow get, list: if isAuthenticated();
      allow create: if isTrafficOrAdmin();
      allow update: if isTrafficOrAdmin();
      allow delete: if false;
    }

    // ============================================================
    // DELEGACIONES AL INSPECTOR (desde Módulo Agentes Digitales — Fix #6)
    //   - Lectura: operadores y admin.
    //   - Creación: cualquier autenticado (operador que delega).
    //   - Update: solo admin/inspector (marcar como acknowledged/completed).
    //   - Delete: prohibido (audit trail).
    // ============================================================
    match /delegaciones_inspector/{document=**} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdminNorm() || isInspector();
      allow delete: if false;
    }

    // ============================================================
    // LÍNEAS UCOT — recorridos, paradas y shapes de líneas UCOT
    //   (Navegador: NavigationModule → getLineaData).
    //   - Lectura: cualquier autenticado (conductores, tráfico, admin).
    //   - Escritura: admin/superadmin (sync desde shapes_cross_operator pendiente).
    //   Fix 2026-04-25: regla explícita para evitar ambigüedad con fallback default.
    // ============================================================
    match /lineas_ucot/{document=**} {
      allow get, list: if isAuthenticated();
      allow write: if isAdminNorm();
    }

    // ============================================================
    // CATEGORÍAS DE SERVICIOS (service_categories — selector de tipos de turno)
    //   - Lectura: cualquier autenticado (tráfico + operaciones).
    //   - Escritura: solo admin (tabla de configuración estática).
    // ============================================================
    match /service_categories/{document=**} {
      allow read: if isAdminNorm() || isTrafficOrAdmin();
      allow write: if isAdminNorm();
    }

    // ============================================================
    // MATRICES DE SERVICIO v2 (service_matrices — programación cross-operador)
    //   - Lectura: tráfico + admin (datos operativos sensibles).
    //   - Escritura: solo admin.
    //   Index requerido: empresaId ASC + createdAt DESC (firestore.indexes.json).
    // ============================================================
    match /service_matrices/{document=**} {
      allow read: if isAdminNorm() || isTrafficOrAdmin();
      allow write: if isAdminNorm();
    }

    // ============================================================
    // REGLA DEFAULT — Lectura permitida para autenticados, escritura protegida
    // ============================================================
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminNorm();
    }
  }
}
