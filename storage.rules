rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // --- HELPERS ---
    function isAuth() {
      return request.auth != null;
    }

    // --- RULES ---

    // 1. Evidence & Uploads (Standard Users)
    // Allow upload, prevent overwrite of existing (integrity), prevent delete.
    match /{allPaths=**} {
      allow read: if isAuth();
      
      // Allow creation (upload)
      allow create: if isAuth();
      
      // Allow update (edit metadata/rewrite) - Optional, can restrict if needed
      allow update: if isAuth();

      // 🛡️ CRITICAL: HARD DELETE PROTECTION
      // Only allow delete if custom claim 'super_admin' is true OR 
      // (Simplified) We BLOCK it completely for standard users.
      // To really delete, one must use the Firebase Console or contain the specific 'SuperAdmin' Token.
      // For now: BLOCK DELETE for app users to prevent fraud.
      allow delete: if false; 
    }
  }
}
