rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Regla específica para reportes y evidencias
    match /reportes/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024; // Máx 10MB
    }
    // Regla para la carpeta de sanciones (usada en el componente actual)
    match /sanciones/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024;
    }
  }
}
