{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "rootDirectory": "backend",
        "builder": "NIXPACKS",
        "nixpacksPlan": {
            "providers": [
                "node"
            ],
            "phases": {
                "setup": {
                    "nixPkgs": [
                        "nodejs",
                        "openssl"
                    ]
                },
                "install": {
                    "cmds": [
                        "npm ci"
                    ]
                },
                "build": {
                    "cmds": [
                        "npx prisma generate",
                        "npm run build"
                    ]
                }
            }
        }
    },
    "deploy": {
        "startCommand": "npm start",
        "restartPolicyType": "ON_FAILURE"
    }
}