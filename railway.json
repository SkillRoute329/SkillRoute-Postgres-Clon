{
    "build": {
        "builder": "NIXPACKS"
    },
    "deploy": {
        "healthcheckPath": "/api/health",
        "healthcheckTimeout": 120,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 5
    },
    "nixpacks": {
        "variables": {
            "NPM_CONFIG_PRODUCTION": "false"
        }
    }
}