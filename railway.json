{
    "deploy": {
        "numKeep": 5,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
    },
    "build": {
        "builder": "NIXPACKS",
        "nixpacksPlan": {
            "phases": {
                "setup": {
                    "nixPkgs": [
                        "nodejs",
                        "openssl"
                    ]
                },
                "install": {
                    "cmds": [
                        "npm ci"
                    ]
                },
                "build": {
                    "cmds": [
                        "npx prisma generate",
                        "npm run build"
                    ]
                }
            }
        }
    }
}