{
    "build": {
        "builder": "NIXPACKS"
    },
    "deploy": {
        "healthcheckPath": "/api/health",
        "healthcheckTimeout": 120,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 5
    },
    "nixpacks": {
        "phases": {
            "setup": {
                "nixPkgs": [
                    "nodejs_22",
                    "npm-9_x",
                    "openssl",
                    "chromium",
                    "glib",
                    "nss",
                    "freetype",
                    "fontconfig",
                    "harfbuzz",
                    "ca-certificates",
                    "ttf-freefont",
                    "postgresql",
                    "atk",
                    "cups",
                    "dbus",
                    "libdrm",
                    "gtk3",
                    "pango",
                    "cairo",
                    "at-spi2-atk",
                    "at-spi2-core",
                    "alsa-lib",
                    "mesa",
                    "libx11",
                    "libxcomposite",
                    "libxdamage",
                    "libxext",
                    "libxfixes",
                    "libxrandr",
                    "libxrender",
                    "libxtst",
                    "libxcb"
                ]
            }
        },
        "variables": {
            "NPM_CONFIG_PRODUCTION": "false",
            "PUPPETEER_SKIP_CHROMIUM_DOWNLOAD": "true",
            "PUPPETEER_EXECUTABLE_PATH": "/usr/bin/chromium"
        }
    }
}