    "main": "lib/index.js",
    "scripts": {
        "serve": "npm run build && firebase emulators:start --only functions",
        "build": "tsc && node -e \"const fs=require('fs'),path=require('path');fs.mkdirSync('lib/data',{recursive:true});['ucot_personal','ucot_vehicles','ucot_servicios_habiles','ucot_servicios_sabado','ucot_boletin','ucot_flota_marcas','ucot_rotacion','ucot_boletin_verano'].forEach(f=>{const src='src/data/'+f+'.json';if(fs.existsSync(src))fs.copyFileSync(src,'lib/data/'+f+'.json');})\"",
        "deploy": "npm run build && firebase deploy --only functions"
    },
