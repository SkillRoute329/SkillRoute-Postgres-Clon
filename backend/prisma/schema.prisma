
// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

// 0. Tenants (Empresas)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 0. Tenants (Empresas)
model Tenant {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                   User[]
  shiftCategories         ShiftCategory[]
  shifts                  Shift[]
  customFieldDefinitions  CustomFieldDefinition[]
  systemConfigs           SystemConfig[]
  payments                Payment[]
  actionLogs              ActionLog[]
  vehicles                Vehicle[]
  inspections             Inspection[]
  departments             Department[] 
  jobRoles                JobRole[]
  maintenanceReports      MaintenanceReport[] 
  discountCategories      DiscountCategory[]
  seasons                 Season[]
  serviceDefinitions      ServiceDefinition[]
  rotationSchemes         RotationScheme[]
  serviceRanges           ServiceRange[]
  bulletinEntries         BulletinEntry[]
  penaltyRules            PenaltyRule[]
  userPenalties           UserPenalty[]
  roadAlerts              RoadAlert[]
  shiftRequests           ShiftRequest[]
}

// 1. Usuarios
model User {
  id             Int       @id @default(autoincrement())
  tenantId       Int       @default(1) 
  internalNumber String
  firstName      String
  lastName       String
  fullName       String
  email          String?
  phoneNumber    String?   @map("phonenumber")
  whatsappLink   String?
  passwordHash   String
  role           String    @default("User")
  departmentId   Int?
  department     Department? @relation(fields: [departmentId], references: [id])
  jobRoleId      Int?
  jobRole        JobRole?    @relation(fields: [jobRoleId], references: [id])
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  lastLogin      DateTime?

  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  shiftsCreated   Shift[]   @relation("CreatedBy")
  shiftsAssigned  Shift[]   @relation("AssignedTo")
  approvals       Shift[]   @relation("ApprovedBy")
  transactions    ShiftTransaction[]
  payments        Payment[]
  actionLogs      ActionLog[]
  notifications   Notification[]
  inspections     Inspection[]
  
  // New Fields for Fleet Management
  internalId      String?   @unique // Nuevo campo solicitado (ej: "329")
  driverType      String    @default("FIXED") // Deprecated/Legacy
  
  driverStatus    DriverStatus @default(A_LA_ORDEN) // EFECTIVO_COCHE, A_LA_ORDEN_LISTA, LICENCIA_MEDICA
  rotationScheme  PersonalRotationScheme @default(ESTANDAR_15x15) // ESTANDAR_15x15, SEMANAL, etc.
  
  assignedVehicleId Int?
  assignedVehicle Vehicle?  @relation("VehicleDrivers", fields: [assignedVehicleId], references: [id])
  
  fairnessScore   Int       @default(100)
  preferredPartnerId Int?   // ID de otro Usuario (Compañero)
  
  reportsMade     MaintenanceReport[] @relation("Reporter")
  maintenanceLogs MaintenanceLog[]
  bulletinEntries BulletinEntry[]
  userPenalties   UserPenalty[]
  shiftRequests   ShiftRequest[]

  @@unique([tenantId, internalNumber])
  @@unique([tenantId, email])
}

enum DriverStatus {
  EFECTIVO_COCHE
  A_LA_ORDEN
  A_LA_ORDEN_LISTA
  LICENCIA_MEDICA
  VACACIONES
}

enum PersonalRotationScheme {
  ESTANDAR_15x15
  SEMANAL
  FIJO_MANANA
  FIJO_TARDE
  ROTACION_DE_TRES
}

enum RequestType {
  CORRELATIVO
  MEDICO
  CAMBIO_HORARIO
  PASE_A_LISTA
}

enum RequestStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

model ShiftRequest {
  id              String         @id @default(uuid())
  tenantId        Int            @default(1)
  requesterId     Int
  type            RequestType
  
  targetDate      DateTime
  targetShiftIndex Int?          // Para indicar qué turno del día (1, 2, 3)
  
  comments        String?
  agreedWithPartnerId Int?       // Si es un cambio con otro
  
  status          RequestStatus  @default(PENDIENTE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  requester       User           @relation(fields: [requesterId], references: [id])
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
}


// 1.5. Departamentos (Departments - Áreas de Trabajo)
model Department {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @default(1)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  users       User[]
  jobRoles    JobRole[] // Cargos asociados
  maintenanceReports MaintenanceReport[] 

  @@unique([tenantId, name])
}

// 1.6 Cargos (Job Roles)
model JobRole {
  id           Int        @id @default(autoincrement())
  tenantId     Int        @default(1)
  departmentId Int
  name         String
  description  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  department   Department @relation(fields: [departmentId], references: [id])
  users        User[]

  // Salarios (New Fields)
  baseSalary      Decimal   @default(0.00) // Valor Jornal / Salario Base
  extraHourValue  Decimal   @default(0.00)

  @@unique([tenantId, departmentId, name])
}

// 1.7 Descuentos (RRHH)
model DiscountCategory {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @default(1)
  name      String   // "BPS", "IRPF", "Adelanto", "Sindicato"
  type      String   // "PERCENTAGE", "FIXED"
  value     Decimal  // 15.0 or 2000.0
  isActive  Boolean  @default(true)
  
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([tenantId, name])
}

// 2. Categorías de turnos
model ShiftCategory {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @default(1)
  name           String
  baseValue      Decimal
  extraHourValue Decimal
  createdBy      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  shifts         Shift[]  @relation("CategoryToShift")
  priceHistory   ShiftCategoryPriceHistory[]

  @@unique([tenantId, name]) // Name must be unique within the tenant
}

model ShiftCategoryPriceHistory {
  id             Int           @id @default(autoincrement())
  categoryId     Int
  baseValue      Decimal
  extraHourValue Decimal
  effectiveDate  DateTime
  createdAt      DateTime      @default(now())

  category       ShiftCategory @relation(fields: [categoryId], references: [id])
}

// 3. Turnos
model Shift {
  id                       Int           @id @default(autoincrement())
  tenantId                 Int           @default(1)
  categoryId               Int
  serviceNumber            String
  date                     DateTime
  time                     String
  endTime                  String?
  line                     String
  relief                   String?
  carNumber                String
  extraHours               Decimal       @default(0.00)
  tip                      Boolean       @default(false)
  tipValue                 Decimal       @default(0.00)
  totalValue               Decimal
  transformaFacil          Boolean       @default(false)
  transformaFacilDiscount  Decimal       @default(0.00)
  isPaid                   Boolean       @default(false)
  customValues             String?
  status                   String        @default("Created")
  createdBy                Int
  assignedTo               Int?
  approvedBy               Int?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  deletedAt                DateTime?     // Soft Delete

  tenant                   Tenant        @relation(fields: [tenantId], references: [id])
  category                 ShiftCategory @relation("CategoryToShift", fields: [categoryId], references: [id])
  creator                  User          @relation("CreatedBy", fields: [createdBy], references: [id])
  assignee                 User?         @relation("AssignedTo", fields: [assignedTo], references: [id])
  approver                 User?         @relation("ApprovedBy", fields: [approvedBy], references: [id])
  transactions             ShiftTransaction[]
}

// 4. Transacciones
model ShiftTransaction {
  id                Int      @id @default(autoincrement())
  shiftId           Int
  userId            Int
  type              String
  amount            Decimal
  transactionDate   DateTime @default(now())

  shift             Shift    @relation(fields: [shiftId], references: [id])
  user              User     @relation(fields: [userId], references: [id])
}

// 5. Campos Dinámicos
model CustomFieldDefinition {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @default(1)
  name        String
  label       String
  type        String
  required    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

// 6. Configuración del Sistema
model SystemConfig {
  key         String
  tenantId    Int      @default(1)
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  @@id([tenantId, key]) // Key is unique per tenant
}

// 7. Pagos Parciales
model Payment {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @default(1)
  userId    Int
  amount    Decimal
  date      DateTime @default(now())
  isClosed  Boolean  @default(false)
  notes     String?
  deletedAt DateTime? // Soft Delete
  
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

// 8. Audit Logs (Logs de Acciones Críticas)
model ActionLog {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  userId      Int?
  action      String   // e.g., 'CREATE_SHIFT', 'DELETE_SHIFT', 'LOGIN'
  details     String?  // JSON or Text details
  ipAddress   String?
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
}

// 9. Notificiones
model Notification {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @default(1)
  userId    Int
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

// --- FLOTA / FLEET MANAGEMENT (New Features) ---


// 10. Vehículos
model Vehicle {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @default(1)
  internalNumber String   // Número de coche
  plate          String?
  
  // Detalles ampliados
  make           String?
  model          String?
  year           Int?
  features       String?  // JSON
  
  status         String   @default("OPERATIONAL") // OPERATIONAL, MAINTENANCE, STOPPED
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  inspections    Inspection[]
  reports        MaintenanceReport[]
  
  assignedDrivers User[]  @relation("VehicleDrivers")
  
  serviceDefinitions ServiceDefinition[]

  rotationSchemeId Int?
  rotationScheme   RotationScheme? @relation(fields: [rotationSchemeId], references: [id])

  @@unique([tenantId, internalNumber])
}

// 13. Reportes de Mantenimiento / Denuncias
model MaintenanceReport {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @default(1)
  
  vehicleId      Int
  reporterId     Int
  departmentId   Int?
  
  title          String
  description    String
  priority       String   @default("NORMAL")
  status         String   @default("PENDING")
  photoUrl       String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  vehicle        Vehicle        @relation(fields: [vehicleId], references: [id])
  reporter       User           @relation("Reporter", fields: [reporterId], references: [id])
  department     Department?    @relation(fields: [departmentId], references: [id])
  
  logs           MaintenanceLog[]
}

model MaintenanceLog {
  id             Int      @id @default(autoincrement())
  reportId       Int
  userId         Int
  
  action         String
  description    String?
  newStatus      String?
  photoUrl       String?
  
  createdAt      DateTime @default(now())
  
  report         MaintenanceReport @relation(fields: [reportId], references: [id])
  user           User              @relation(fields: [userId], references: [id])
}

// 10.1 Gestión de Temporadas (Verano/Invierno)
model Season {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  name        String   // "Verano 2026"
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean  @default(true)

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  serviceDefinitions ServiceDefinition[]
  rotations   RotationScheme[]
}

// 10.2 Definición del Servicio (El "Cartón" Digital)
model ServiceDefinition {
  id            Int      @id @default(autoincrement())
  tenantId      Int
  seasonId      Int
  
  serviceCode   String   @default("0000") // Nuevo ID lógico (Ej: "1100")
  serviceNumber String   // "2290" - Legado, se mantiene por compatibilidad UI
  line          String   // "300"
  variant       String?  // "Sabadero", "Habil" - Descriptivo
  
  dayType       String   @default("HABIL") // "HABIL", "SABADO", "DOMINGO" - CRÍTICO PARA MATRIZ
  vehicleType   String   @default("DIESEL") // "HIBRIDO", "B7", "MT15"
  
  // Datos Estructurales (Fijos para este cartón)
  startTime     String   // "04:25"
  endTime       String   // "20:24"
  totalHours    String?
  liquidHours   String?
  kilometers    String?
  
  // Detalle de paradas y horarios (JSON para flexibilidad)
  // Ej: [{location: "Pza. Cerro", time: "06:15"}, ...]
  routeData     String   // JSON

  assignedVehicleId Int?
  assignedVehicle   Vehicle? @relation(fields: [assignedVehicleId], references: [id])

  season        Season   @relation(fields: [seasonId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  // REGLA DE UNICIDAD ACTUALIZADA:
  // Un servicio (1100) es único por Temporada y Tipo de Día.
  // Ej: Servicio 1100 HABIL Verano != Servicio 1100 SABADO Verano != Servicio 1100 HABIL Invierno
  @@unique([tenantId, seasonId, serviceCode, dayType])
}

// 10.3 Esquemas de Rotación (Lógica Cíclica)
model RotationScheme {
  id            Int      @id @default(autoincrement())
  tenantId      Int
  seasonId      Int
  name          String   // "Rotación Yutong Híbridos"
  
  // Configuración de la Rotación
  frequency     String   // "Weekly", "Cyclic"
  daysOfWeek    String   // "Mon-Fri", "Sat", "Sun", "All"
  
  // Fechas específicas si la rotación no cubre toda la temporada
  startDate     DateTime? 
  endDate       DateTime?

  cycleLength   Int      // Cuántos pasos tiene el ciclo
  
  // La Secuencia: [{step: 1, serviceRange: "2010"}, {step: 2, serviceRange: "2011"}]
  sequenceData  String   // JSON
  
  season        Season   @relation(fields: [seasonId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  vehicles      Vehicle[]
}

// 10.4 Rangos de Servicio (Simple - Conservado por compatibilidad o uso rápido)
model ServiceRange {
  id            Int      @id @default(autoincrement())
  tenantId      Int
  name          String   // "Yutong Hibridos General"
  minService    Int
  maxService    Int
  allowedBrand  String?
  allowedModel  String?
  days          String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
}

// 11. Inspecciones (El Relevo Digital)
model Inspection {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  vehicleId   Int
  userId      Int      // Inspector Driver
  type        String   // 'StartShift', 'EndShift', 'Audit'
  odometer    Int?     
  fuelLevel   String?  // 'Full', '3/4', '1/2', 'Reserve'
  status      String   // 'OK', 'WithDamages'
  notes       String?
  createdAt   DateTime @default(now())

  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  vehicle     Vehicle       @relation(fields: [vehicleId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
  damages     DamageReport[]
}

// 12. Reporte de Daños (Evidencia)
model DamageReport {
  id            Int      @id @default(autoincrement())
  inspectionId  Int
  zone          String   // 'Front', 'Right', 'Left', 'Back', 'Interior'
  severity      String   @default("Medium") // Low, Medium, High
  description   String
  photoUrl      String?  
  createdAt     DateTime @default(now())
  
  inspection    Inspection @relation(fields: [inspectionId], references: [id])
}

// 14. Boletines (Registro de Tiempos Reales)
model BulletinEntry {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @default(1)
  inspectorId    Int
  
  date           DateTime
  serviceNumber  String
  
  location       String
  scheduledTime  String
  actualTime     String?
  delayMinutes   Int      @default(0)
  
  busNumber      String?
  occupancyCount Int?
  occupancyLevel String?
  status         String   @default("Completed")
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  inspector      User     @relation(fields: [inspectorId], references: [id])

  @@index([tenantId, serviceNumber])
}

// 15. Sistema de Penalizaciones (Conducta)
model PenaltyRule {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @default(1)
  name           String   // e.g. "Adelantos Excesivos"
  description    String?
  type           String   // 'EarlyArrival', 'LateArrival', 'LowLoad'
  threshold      Float    // e.g. 5 (minutes early)
  maxCount       Int      // e.g. 10 (occurrences)
  periodDays     Int      @default(7) // e.g. 7 days window
  action         String   // 'Suspension', 'Warning'
  actionDuration Int?     // e.g. 1 (day)
  isActive       Boolean  @default(true)
  
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
}

model UserPenalty {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @default(1)
  userId         Int
  ruleId         Int?     // Optional link to rule
  reason         String
  type           String   // 'Suspension', 'Warning'
  startDate      DateTime @default(now())
  durationDays   Int?
  status         String   @default("Active") // 'Active', 'Served', 'Forgiven'
  notes          String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  user           User     @relation(fields: [userId], references: [id])
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
}

// 16. Alertas Viales (Wayze del Bus)
model RoadAlert {
  id              Int      @id @default(autoincrement())
  tenantId        Int      @default(1)
  title           String   // "Desvío por Feria", "Accidente en Propios"
  description     String   // "Tomar 8 de Octubre hasta Pan de Azúcar..."
  type            String   // "ACCIDENTE", "FERIA", "DESVIO", "MANIFESTACION", "OBRAS"
  affectedLine    String?  // "370", "Todas", "105"
  severity        String   @default("MEDIUM") // "LOW", "MEDIUM", "HIGH"
  latitude        Float    @default(0) // Geo-location
  longitude       Float    @default(0)
  radiusMeters    Int      @default(500) // Area of effect
  isActive        Boolean  @default(true)
  expiresAt       DateTime? // Auto-borrado opcional
  createdAt       DateTime @default(now())
  createdBy       Int?

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
}
