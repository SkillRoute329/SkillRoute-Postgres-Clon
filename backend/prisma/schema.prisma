
// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

// 0. Tenants (Empresas)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 0. Tenants (Empresas)
model Tenant {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                   User[]
  shiftCategories         ShiftCategory[]
  shifts                  Shift[]
  customFieldDefinitions  CustomFieldDefinition[]
  systemConfigs           SystemConfig[]
  payments                Payment[]
  actionLogs              ActionLog[]
  vehicles                Vehicle[]
  inspections             Inspection[]
  departments             Department[] 
  jobRoles                JobRole[]
  maintenanceReports      MaintenanceReport[] 
  discountCategories      DiscountCategory[]
  seasons                 Season[]
  serviceDefinitions      ServiceDefinition[]
  rotationSchemes         RotationScheme[]
  serviceRanges           ServiceRange[]
  bulletinEntries         BulletinEntry[]
  penaltyRules            PenaltyRule[]
  userPenalties           UserPenalty[]
  roadAlerts              RoadAlert[]
  shiftRequests           ShiftRequest[]
  plannedDetours          PlannedDetour[]
  radars                  Radar[]
  tariffZones             TariffZone[]
  parts                   Part[]
  vehicleChecks           VehicleCheck[]
  incidents               Incident[]
  fleetCategories         FleetCategory[]
}

// 18. Rutas Maestras (Shapefiles & Tarifas)
// 18. Rutas (Contenedor de Línea)
model Route {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @default(1)
  name        String   // "306", "71"
  description String?
  type        String   @default("URBANA") // URBANA, SUBURBANA, LOCAL
  
  variants    RouteVariant[]
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Universal Extensions
  metadata    Json?    @default("{}")
  status      String   @default("ACTIVE")

  @@unique([tenantId, name])
}

// 18.2 Variantes de Ruta (Ida, Vuelta, Ramales)
model RouteVariant {
  id          Int      @id @default(autoincrement())
  routeId     Int
  
  name        String   // "Hacia Casabó (A)", "Hacia Géant (Directo)"
  origin      String
  destination String
  
  geometry    String?   // JSON Polyline format (Dense)
  isActive    Boolean  @default(true)

  // Universal Extensions
  description String?
  metadata    Json?    @default("{}")
  status      String   @default("ACTIVE")

  route       Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  
  tariffZones TariffZone[] 
  sequences   RouteSequence[]
  trips       TripSchedule[]

  @@unique([routeId, name])
}

// 18.3 Secuencia de Paradas (Del Cartón)
model RouteSequence {
  id          Int      @id @default(autoincrement())
  variantId   Int
  stopName    String   // "Tres Cruces", "Belloni"
  order       Int      // 0, 1, 2...
  
  variant     RouteVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  tripTimes   TripTime[]
  
  @@unique([variantId, order])
}

// 18.4 Horarios de Viaje (Del Cartón)
model TripSchedule {
  id          Int      @id @default(autoincrement())
  variantId   Int
  serviceId   String?  // "1009"
  dayType     String   // "Habil", "Sabado", "Domingo"
  startTime   String   // "06:00"
  
  variant     RouteVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  times       TripTime[]

  // Universal Extensions
  metadata    Json?    @default("{}")
  status      String   @default("ACTIVE")
}

// 18.5 Tiempos por Parada
model TripTime {
  id              Int           @id @default(autoincrement())
  tripScheduleId  Int
  sequenceId      Int
  
  time            String        // "06:15" or empty if skipped
  
  trip            TripSchedule  @relation(fields: [tripScheduleId], references: [id], onDelete: Cascade)
  sequence        RouteSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
}

// 19. Zonas Tarifarias (Geocercas de cambio de precio)
model TariffZone {
  id              Int      @id @default(autoincrement())
  variantId       Int      // Linked to specific variant
  
  name            String   // "Urbana", "Centrica", "Zonal E", "Sección 1"
  type            String   @default("POINT") // POINT (Limit), POLYGON, CIRCLE
  price           Float?   // Precio Común
  differentialPrice Float? // Precio Diferencial (Nuevo)
  latitude        Float    // Centro o punto de cruce
  longitude       Float
  geometry        String?  // JSON para polígonos ([ [lat,lng], ... ])
  radiusMeters    Int      @default(100)
  order           Int      @default(0)
  
  variant         RouteVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  
  tenantId        Int      @default(1)
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
}

// 20. Radares y Puntos de Control (Alertas de Velocidad)
model Radar {
  id              Int      @id @default(autoincrement())
  tenantId        Int      @default(1)
  name            String   // "Radar Av. Italia y Bolivia"
  latitude        Float
  longitude       Float
  speedLimit      Int      // 45, 60, 75
  type            String   // "CAMERA", "RADAR", "DANGEROUS_CURVE"
  
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
}

// 1. Usuarios (Updated to include Employee Data directly)
model User {
  id             Int       @id @default(autoincrement())
  tenantId       Int       @default(1) 
  internalNumber String    // Legajo / ID Interno
  ci             String?   @unique // Cédula de Identidad (New)
  firstName      String
  lastName       String
  fullName       String
  email          String?
  phoneNumber    String?   @map("phonenumber")
  whatsappLink   String?
  passwordHash   String
  role           String    @default("User")
  departmentId   Int?
  department     Department? @relation(fields: [departmentId], references: [id])
  jobRoleId      Int?
  jobRole        JobRole?    @relation(fields: [jobRoleId], references: [id])
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  lastLogin      DateTime?

  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  shiftsCreated   Shift[]   @relation("CreatedBy")
  shiftsAssigned  Shift[]   @relation("AssignedTo")
  approvals       Shift[]   @relation("ApprovedBy")
  transactions    ShiftTransaction[]
  payments        Payment[]
  actionLogs      ActionLog[]
  notifications   Notification[]
  inspections     Inspection[]
  
  // New Fields for Fleet Management
  internalId      String?   @unique 
  driverType      String    @default("FIXED") // Deprecated/Legacy
  
  driverStatus    DriverStatus @default(A_LA_ORDEN) // EFECTIVO_COCHE, A_LA_ORDEN_LISTA, LICENCIA_MEDICA
  rotationScheme  PersonalRotationScheme @default(ESTANDAR_15x15) // ESTANDAR_15x15, SEMANAL, etc.
  
  assignedVehicleId Int?
  assignedVehicle Vehicle?  @relation("VehicleDrivers", fields: [assignedVehicleId], references: [id])
  
  fairnessScore   Int       @default(100)
  preferredPartnerId Int?   // ID de otro Usuario (Compañero)
  
  reportsMade     MaintenanceReport[] @relation("Reporter")
  maintenanceLogs MaintenanceLog[]
  bulletinEntries BulletinEntry[]
  userPenalties   UserPenalty[]
  shiftRequests   ShiftRequest[]
  vehicleChecks   VehicleCheck[]

  // Universal Extensions
  incidentsReported Incident[]
  incidentLogs    IncidentLog[]
  photoUrl        String?
  avatarUrl       String?   @db.Text // Ruta local almacenamiento
  metadata        Json?     @default("{}")
  status          String    @default("ACTIVE")

  employee        Employee? // Link to separated Employee record

  @@unique([tenantId, internalNumber])
  @@unique([tenantId, email])
}

// 1.1 Empleados (Legajo Completo)
model Employee {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  ci        String   @unique
  position  String   // Cargo manual o relacionado
  photoUrl  String?
  
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ... (Rest of Schema - Preserving Enums and Models)
enum DriverStatus {
  EFECTIVO_COCHE
  A_LA_ORDEN
  A_LA_ORDEN_LISTA
  LICENCIA_MEDICA
  VACACIONES
}

enum PersonalRotationScheme {
  ESTANDAR_15x15
  SEMANAL
  FIJO_MANANA
  FIJO_TARDE
  ROTACION_DE_TRES
}

enum RequestType {
  CORRELATIVO
  MEDICO
  CAMBIO_HORARIO
  PASE_A_LISTA
}

enum RequestStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

model ShiftRequest {
  id              String         @id @default(uuid())
  tenantId        Int            @default(1)
  requesterId     Int
  type            RequestType
  
  targetDate      DateTime
  targetShiftIndex Int?          // Para indicar qué turno del día (1, 2, 3)
  
  comments        String?
  agreedWithPartnerId Int?       // Si es un cambio con otro
  
  status          RequestStatus  @default(PENDIENTE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  requester       User           @relation(fields: [requesterId], references: [id])
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
}


// 1.5. Departamentos (Departments - Áreas de Trabajo)
model Department {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @default(1)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  users       User[]
  jobRoles    JobRole[] // Cargos asociados
  maintenanceReports MaintenanceReport[] 

  @@unique([tenantId, name])
}

// 1.6 Cargos (Job Roles)
model JobRole {
  id           Int        @id @default(autoincrement())
  tenantId     Int        @default(1)
  departmentId Int
  name         String
  description  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  department   Department @relation(fields: [departmentId], references: [id])
  users        User[]

  // Salarios (New Fields)
  baseSalary      Decimal   @default(0.00) // Valor Jornal / Salario Base
  extraHourValue  Decimal   @default(0.00)

  @@unique([tenantId, departmentId, name])
}

// 1.7 Descuentos (RRHH)
model DiscountCategory {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @default(1)
  name      String   // "BPS", "IRPF", "Adelanto", "Sindicato"
  type      String   // "PERCENTAGE", "FIXED"
  value     Decimal  // 15.0 or 2000.0
  isActive  Boolean  @default(true)
  
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([tenantId, name])
}

// 2. Categorías de turnos
model ShiftCategory {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @default(1)
  name           String
  baseValue      Decimal
  extraHourValue Decimal
  createdBy      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  shifts         Shift[]  @relation("CategoryToShift")
  priceHistory   ShiftCategoryPriceHistory[]

  @@unique([tenantId, name]) // Name must be unique within the tenant
}

model ShiftCategoryPriceHistory {
  id             Int           @id @default(autoincrement())
  categoryId     Int
  baseValue      Decimal
  extraHourValue Decimal
  effectiveDate  DateTime
  createdAt      DateTime      @default(now())

  category       ShiftCategory @relation(fields: [categoryId], references: [id])
}

// 3. Turnos
model Shift {
  id                       Int           @id @default(autoincrement())
  tenantId                 Int           @default(1)
  categoryId               Int
  serviceNumber            String
  date                     DateTime
  time                     String
  endTime                  String?
  line                     String
  relief                   String?
  carNumber                String
  extraHours               Decimal       @default(0.00)
  tip                      Boolean       @default(false)
  tipValue                 Decimal       @default(0.00)
  totalValue               Decimal
  transformaFacil          Boolean       @default(false)
  transformaFacilDiscount  Decimal       @default(0.00)
  isPaid                   Boolean       @default(false)
  customValues             String?
  status                   String        @default("Created")
  createdBy                Int
  assignedTo               Int?
  approvedBy               Int?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  deletedAt                DateTime?     // Soft Delete

  tenant                   Tenant        @relation(fields: [tenantId], references: [id])
  
  seasonId                 Int?          // SeasonScope: Isolation for drafts/historical data
  season                   Season?       @relation(fields: [seasonId], references: [id])

  category                 ShiftCategory @relation("CategoryToShift", fields: [categoryId], references: [id])
  creator                  User          @relation("CreatedBy", fields: [createdBy], references: [id])
  assignee                 User?         @relation("AssignedTo", fields: [assignedTo], references: [id])
  approver                 User?         @relation("ApprovedBy", fields: [approvedBy], references: [id])
  transactions             ShiftTransaction[]

  // Universal Extensions
  metadata                 Json?         @default("{}")
  // status already exists
}

// 4. Transacciones
model ShiftTransaction {
  id                Int      @id @default(autoincrement())
  shiftId           Int
  userId            Int
  type              String
  amount            Decimal
  transactionDate   DateTime @default(now())

  shift             Shift    @relation(fields: [shiftId], references: [id])
  user              User     @relation(fields: [userId], references: [id])
}

// 5. Campos Dinámicos
model CustomFieldDefinition {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @default(1)
  name        String
  label       String
  type        String
  required    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

// 6. Configuración del Sistema
model SystemConfig {
  key         String
  tenantId    Int      @default(1)
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  @@id([tenantId, key]) // Key is unique per tenant
}

// 7. Pagos Parciales
model Payment {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @default(1)
  userId    Int
  amount    Decimal
  date      DateTime @default(now())
  isClosed  Boolean  @default(false)
  notes     String?
  deletedAt DateTime? // Soft Delete
  
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

// 8. Audit Logs (Logs de Acciones Críticas)
model ActionLog {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  userId      Int?
  action      String   // e.g., 'CREATE_SHIFT', 'DELETE_SHIFT', 'LOGIN'
  details     String?  // JSON or Text details
  ipAddress   String?
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
}

// 9. Notificiones
model Notification {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @default(1)
  userId    Int
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

// --- FLOTA / FLEET MANAGEMENT (New Features) ---


// 10.A Categorías de Flota (Tecnología)
model FleetCategory {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @default(1)
  name        String   // "Híbrido", "Eléctrico", "Convencional", "Articulado"
  description String?
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  vehicles    Vehicle[]

  @@unique([tenantId, name])
}

// 10. Vehículos
model Vehicle {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @default(1)
  internalNumber String   // Número de coche
  plate          String?
  
  // Detalles ampliados
  make           String?
  model          String?
  year           Int?
  features       String?  // JSON
  docUrl         String?  @db.Text
  
  status         String   @default("OPERATIONAL") // OPERATIONAL, MAINTENANCE, STOPPED
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Fleet Master enhancements
  shiftsCapacity Int      @default(3) // Capacidad de turnos por día (Mañana, Tarde, Nocturno)

  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  inspections    Inspection[]
  reports        MaintenanceReport[]
  
  assignedDrivers User[]  @relation("VehicleDrivers")
  
  serviceDefinitions ServiceDefinition[]

  rotationSchemeId Int?
  rotationScheme   RotationScheme? @relation(fields: [rotationSchemeId], references: [id])

  @@unique([tenantId, internalNumber])
  
  // Universal Extensions
  metadata       Json?    @default("{}")
  // status already exists
}

// 13. Reportes de Mantenimiento / Denuncias
model MaintenanceReport {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @default(1)
  
  vehicleId      Int
  reporterId     Int
  departmentId   Int?
  
  title          String
  description    String
  priority       String   @default("NORMAL")
  status         String   @default("ENVIADO") // ENVIADO, RECIBIDO, EN_PROCESO, PROGRAMADO, DESCARTADO, FINALIZADO
  photoUrl       String?  @db.Text
  evidencePhotos String?  @db.Text // Base64 Text for multiple photos in JSON or single large string
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  vehicle        Vehicle        @relation(fields: [vehicleId], references: [id])
  reporter       User           @relation("Reporter", fields: [reporterId], references: [id])
  department     Department?    @relation(fields: [departmentId], references: [id])
  
  logs           MaintenanceLog[]
  partUsages     PartUsage[]
}

model MaintenanceLog {
  id             Int      @id @default(autoincrement())
  reportId       Int
  userId         Int
  
  action         String
  description    String?
  newStatus      String?
  photoUrl       String?
  
  createdAt      DateTime @default(now())
  
  report         MaintenanceReport @relation(fields: [reportId], references: [id])
  user           User              @relation(fields: [userId], references: [id])
}

// 10.1 Gestión de Temporadas (Verano/Invierno)
model Season {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  name        String   // "Verano 2026"
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean  @default(true)

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  serviceDefinitions ServiceDefinition[]
  rotations   RotationScheme[]
  shifts      Shift[]
}

// 10.2 Definición del Servicio (El "Cartón" Digital)
model ServiceDefinition {
  id            Int      @id @default(autoincrement())
  tenantId      Int
  seasonId      Int
  
  serviceCode   String   @default("0000") // Nuevo ID lógico (Ej: "1100")
  serviceNumber String   // "2290" - Legado, se mantiene por compatibilidad UI
  line          String   // "300"
  variant       String?  // "Sabadero", "Habil" - Descriptivo
  
  dayType       String   @default("HABIL") // "HABIL", "SABADO", "DOMINGO" - CRÍTICO PARA MATRIZ
  vehicleType   String   @default("DIESEL") // "HIBRIDO", "B7", "MT15"
  
  // Datos Estructurales (Fijos para este cartón)
  startTime     String   // "04:25"
  endTime       String   // "20:24"
  totalHours    String?
  liquidHours   String?
  kilometers    String?
  
  // Detalle de paradas y horarios (JSON para flexibilidad)
  // Ej: [{location: "Pza. Cerro", time: "06:15"}, ...]
  routeData     String   // JSON

  assignedVehicleId Int?
  assignedVehicle   Vehicle? @relation(fields: [assignedVehicleId], references: [id])

  season        Season   @relation(fields: [seasonId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  // REGLA DE UNICIDAD ACTUALIZADA:
  // Un servicio (1100) es único por Temporada y Tipo de Día.
  // Ej: Servicio 1100 HABIL Verano != Servicio 1100 SABADO Verano != Servicio 1100 HABIL Invierno
  @@unique([tenantId, seasonId, serviceCode, dayType])
}

// 10.3 Esquemas de Rotación (Lógica Cíclica)
model RotationScheme {
  id            Int      @id @default(autoincrement())
  tenantId      Int
  seasonId      Int
  name          String   // "Rotación Yutong Híbridos"
  
  // Configuración de la Rotación
  frequency     String   // "Weekly", "Cyclic"
  daysOfWeek    String   // "Mon-Fri", "Sat", "Sun", "All"
  
  // Fechas específicas si la rotación no cubre toda la temporada
  startDate     DateTime? 
  endDate       DateTime?

  cycleLength   Int      // Cuántos pasos tiene el ciclo
  
  // La Secuencia: [{step: 1, serviceRange: "2010"}, {step: 2, serviceRange: "2011"}]
  sequenceData  String   // JSON
  
  season        Season   @relation(fields: [seasonId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  vehicles      Vehicle[]
}

// 10.4 Rangos de Servicio (Simple - Conservado por compatibilidad o uso rápido)
model ServiceRange {
  id            Int      @id @default(autoincrement())
  tenantId      Int
  name          String   // "Yutong Hibridos General"
  minService    Int
  maxService    Int
  allowedBrand  String?
  allowedModel  String?
  days          String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
}

// 11. Inspecciones (El Relevo Digital)
model Inspection {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  
  vehicleId   Int
  userId      Int
  
  type        String   // StartShift, EndShift, Audit
  odometer    Float?
  fuelLevel   String?
  
  status      String   @default("OK") // OK, WithDamages
  notes       String?  @db.Text
  
  createdAt   DateTime @default(now())
  
  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  damages     DamageReport[]

  @@index([vehicleId])
  @@index([userId])
  @@index([tenantId])
  @@index([createdAt])
}

// 12. Reporte de Daños (Evidencia)
model DamageReport {
  id            Int      @id @default(autoincrement())
  
  inspectionId  Int
  
  zone          String
  description   String   @db.Text
  severity      String   @default("Medium")
  photoUrl      String?  @db.Text
  createdAt     DateTime @default(now())
  
  inspection    Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
}

// 14. Boletines (Registro de Tiempos Reales)
model BulletinEntry {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @default(1)
  inspectorId    Int
  
  date           DateTime
  serviceNumber  String
  
  location       String
  scheduledTime  String
  actualTime     String?
  delayMinutes   Int      @default(0)
  
  busNumber      String?
  occupancyCount Int?
  occupancyLevel String?
  status         String   @default("Completed")
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  inspector      User     @relation(fields: [inspectorId], references: [id])

  @@index([tenantId, serviceNumber])
  @@index([tenantId, date])
}

// 15. Sistema de Penalizaciones (Conducta)
model PenaltyRule {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @default(1)
  name           String   // e.g. "Adelantos Excesivos"
  description    String?
  type           String   // 'EarlyArrival', 'LateArrival', 'LowLoad'
  threshold      Float    // e.g. 5 (minutes early)
  maxCount       Int      // e.g. 10 (occurrences)
  periodDays     Int      @default(7) // e.g. 7 days window
  action         String   // 'Suspension', 'Warning'
  actionDuration Int?     // e.g. 1 (day)
  isActive       Boolean  @default(true)
  
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
}

model UserPenalty {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @default(1)
  userId         Int
  ruleId         Int?     // Optional link to rule
  reason         String
  type           String   // 'Suspension', 'Warning'
  startDate      DateTime @default(now())
  durationDays   Int?
  status         String   @default("Active") // 'Active', 'Served', 'Forgiven'
  notes          String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  user           User     @relation(fields: [userId], references: [id])
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
}

// 16. Alertas Viales (Wayze del Bus)
model RoadAlert {
  id              Int      @id @default(autoincrement())
  tenantId        Int      @default(1)
  title           String   // "Desvío por Feria", "Accidente en Propios"
  description     String   // "Tomar 8 de Octubre hasta Pan de Azúcar..."
  type            String   // "ACCIDENTE", "FERIA", "DESVIO", "MANIFESTACION", "OBRAS"
  affectedLine    String?  // "370", "Todas", "105"
  severity        String   @default("MEDIUM") // "LOW", "MEDIUM", "HIGH"
  latitude        Float    @default(0) // Geo-location
  longitude       Float    @default(0)
  radiusMeters    Int      @default(500) // Area of effect
  isActive        Boolean  @default(true)
  expiresAt       DateTime? // Auto-borrado opcional
  createdAt       DateTime @default(now())
  createdBy       Int?

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
}

// 17. Desvíos Programados (Ferias, Eventos)
model PlannedDetour {
  id              Int      @id @default(autoincrement())
  tenantId        Int      @default(1)
  name            String   // "Feria Piedras Blancas"
  affectedLines   String   // JSON Array or CSV: ["306", "300"]
  days            String   // JSON Array: ["MON", "TUE"]
  startTime       String   // "06:00"
  endTime         String   // "14:00"

  // Detalles de Obra (Nuevo)
  street          String?
  startSection    String?
  endSection      String?
  startDate       DateTime?
  endDate         DateTime?
  
  geometry        String   // JSON Polyline: [[lat,lng], [lat,lng]...]
  
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
}

// Stock Parts
model Part {
  id            Int      @id @default(autoincrement())
  tenantId      Int      @default(1)
  sku           String
  description   String
  category      String   // 'CONSUMIBLES', 'MOTORES', etc.
  currentStock  Int      @default(0)
  minStock      Int      @default(5)
  location      String?
  unitCost      Decimal?
  
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  usages        PartUsage[]
}

model PartUsage {
  id            Int      @id @default(autoincrement())
  reportId      Int
  partId        Int
  quantity      Int
  
  report        MaintenanceReport @relation(fields: [reportId], references: [id])
  part          Part              @relation(fields: [partId], references: [id])
}

// 21. Control de Flota (Check-in de Turno)
model VehicleCheck {
  id        String   @id @default(uuid())
  tenantId  Int      @default(1)
  cocheId   String   
  userId    Int
  
  fotos     Json     // ["url1", "url2", "url3", "url4"]
  notas     String?
  estado    String   // 'OK', 'CON_DAÑOS', 'WAIVER'
  
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

// 22. Control de Operaciones (Amanecer)
model ControlEvent {
  id          Int      @id @default(autoincrement())
  tripId      String
  inspectorId String
  type        String   // 'REGULATION_PLUS', 'REGULATION_MINUS'
  minutes     Int
  reason      String
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now())
}

// 23. Incidentes (Sistema Unificado de Activos)
model Incident {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @default(1)
  
  title       String
  description String   @db.Text
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String   @default("MEDIUM")
  
  photoUrl    String?  @db.Text // Ruta local /uploads/incidents/...
  
  reportedBy  Int
  reporter    User     @relation(fields: [reportedBy], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  logs        IncidentLog[]
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model IncidentLog {
  id         Int      @id @default(autoincrement())
  incidentId Int
  actorId    Int
  action     String   // "CREATE", "UPDATE", "UPLOAD_PHOTO", "RESOLVE"
  note       String?  @db.Text
  timestamp  DateTime @default(now())
  
  incident   Incident @relation(fields: [incidentId], references: [id])
  actor      User     @relation(fields: [actorId], references: [id])
}
