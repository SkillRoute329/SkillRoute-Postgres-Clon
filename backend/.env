# ═══════════════════════════════════════════════════════════════════════════
# AMBIENTE LOCAL - TransformaFacil Backend
# ═══════════════════════════════════════════════════════════════════════════

# Node Environment
NODE_ENV=development

# Puertos
PORT=3002
BRIDGE_PORT=3099

# URLs (Local)
BACKEND_URL=http://localhost:3002
BRIDGE_URL=http://localhost:3099
FRONTEND_URL=http://localhost:5173

# Firebase (Usar credenciales de desarrollo)
FIREBASE_PROJECT_ID=transformafacil-dev
FIREBASE_PRIVATE_KEY=your-firebase-private-key-here
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@transformafacil-dev.iam.gserviceaccount.com

# STM API Configuration
STM_API_URL=https://www.montevideo.gub.uy/api/stm
STM_HORARIOS_URL=https://www.montevideo.gub.uy/app/stm/horarios/
STM_TIMEOUT_MS=10000

# Logging
LOG_LEVEL=debug
LOG_FORMAT=combined

# Caché
CACHE_TTL_MINUTES=60

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRATION=24h

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Database
DB_TIMEOUT_MS=30000

# ═══════════════════════════════════════════════════════════════════════════
# IA LOCAL — Ollama
# ═══════════════════════════════════════════════════════════════════════════
# El copiloto táctico (POST /api/ai/chat) usa el modelo HEAVY con tool-calling.
# Llama3.1:8b es el único que el MVP necesita obligatoriamente.
#
# Para instalar los modelos desde PowerShell/CMD:
#   ollama pull llama3.1:8b          # REQUERIDO
#   ollama pull gemma3:4b            # recomendado (FAST)
#   ollama pull qwen2.5-coder:7b     # recomendado (CODER) — NO el 1.5b-base
#   ollama pull nomic-embed-text     # requerido si se usan embeddings/RAG
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL_FAST=gemma3:4b
OLLAMA_MODEL_CODER=qwen2.5-coder:7b
OLLAMA_MODEL_HEAVY=llama3.1:8b
OLLAMA_MODEL_EMBED=nomic-embed-text

# Opcional — fallback a Claude cloud cuando Ollama no responde o el usuario pide /api/ai/cloud
# ANTHROPIC_API_KEY=sk-ant-...
