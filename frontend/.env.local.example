# Copia este archivo como .env.local y completá los valores
# .env.local NO se commitea (está en .gitignore)
# Para producción, los valores van en .env.production

# --- FCM Web Push ---
# Obtener desde: https://console.firebase.google.com/project/ucot-gestor-cloud/settings/cloudmessaging
# → Web configuration → Web Push certificates → "Add certificate" o copiar key existente
# Es una clave PÚBLICA (no secreta), puede ir en .env.production para el build de prod
VITE_FCM_VAPID_KEY=TU_VAPID_KEY_AQUI

# --- API ---
VITE_API_URL=http://localhost:3099
VITE_BRIDGE_URL=http://localhost:3099
VITE_ENVIRONMENT=development
